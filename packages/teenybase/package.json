                "default": "./dist/worker/supabase/auth/admin/generateLink.js"
            }
        },
        "./node/*": {
            "import": {
                "types": "./dist/node/*.d.ts",
                "default": "./dist/node/*.js"
            }
        },
        "./scaffolds/*": {
            "import": {
                "types": "./dist/scaffolds/*.d.ts",
                "default": "./dist/scaffolds/*.js"
            }
        },
        "./package.json": "./package.json"
    },
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.4.3",
        "@cloudflare/workers-types": "^4.20260210.0",
        "@hono/swagger-ui": "^0.5.3",
        "@hono/zod-openapi": "^1.2.1",
        "@hono/zod-validator": "^0.7.6",
        "@tsndr/cloudflare-worker-jwt": "^3.2.1",
        "@types/prompts": "^2.4.9",
        "bcryptjs": "^3.0.3",
        "cac": "^6.7.14",
        "dotenv": "^17.2.4",
        "hono": "^4.11.9",
        "jsep": "^1.4.0",
        "jsonc-parser": "^3.3.1",
        "md5-file": "^5.0.0",
        "picocolors": "^1.1.1",
        "prompts": "^2.4.2",
        "smol-toml": "^1.6.0",
        "workerd": "^1.20260402.1",
        "wrangler": "^4.63.0"
    },
    "peerDependencies": {
