{
    "name": "teenybase",
    "version": "0.0.16",
    "type": "module",
    "bin": {
        "teeny": "bin/teeny.js",
        "teenybase": "bin/teeny.js"
    },
    "scripts": {
        "build": "npm run build-ts && npm run ts-node && npm run js-node",
        "test": "npm run check && npm run vitest && npm run test-check && npm run vitest-worker",
        "watch": "concurrently -n \"r,ts,js\" \"npm run build-ts -- -w --preserveWatchOutput\" \"npm run ts-node -- -w --preserveWatchOutput\" \"npm run js-node -- --watch\"",
        "run-pack": "npm pack",
        "prepare": "npm run build",
        "prepublishOnly": "npm run test",
        "vitest": "vitest run --exclude test/worker --exclude test/cli-proxy.test.ts --exclude test/cli-managed.test.ts",
        "vitest-worker": "vitest run -r test/worker",
        "vitest-init": "npm run test-init && bash scripts/test-init-dev.sh --ci",
        "check": "tsc -p tsconfig.json --pretty --noEmit && tsc -p backend/tsconfig.json --pretty --noEmit",
        "build-ts": "tsc -p tsconfig.json --pretty",
        "ts-node": "tsc -p src/node/tsconfig.json --pretty",
        "js-node": "esbuild src/node/cli.ts --bundle --outfile=dist/node/cli.js --platform=node --format=esm --packages=external --sourcemap",
        "test-check": "tsc -p test/tsconfig.json --pretty --noEmit",
        "run-publish": "git diff --exit-code --name-only origin/master * && npm publish && git tag v$npm_package_version && git push --tags"
    },
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        },
        "./worker": {
            "import": {
                "types": "./dist/worker/index.d.ts",
                "default": "./dist/worker/index.js"
            }
        },
        "./worker/supabase": {
            "import": {
                "types": "./dist/worker/supabase/index.d.ts",
                "default": "./dist/worker/supabase/index.js"
            }
        },
        "./worker/supabase/shared/config": {
            "import": {
                "types": "./dist/worker/supabase/shared/config.d.ts",
                "default": "./dist/worker/supabase/shared/config.js"
            }
        },
        "./worker/supabase/auth/schema": {
            "import": {
                "types": "./dist/worker/supabase/auth/schema.d.ts",
                "default": "./dist/worker/supabase/auth/schema.js"
            }
        },
        "./worker/supabase/auth/signup": {
            "import": {
                "types": "./dist/worker/supabase/auth/signup.d.ts",
                "default": "./dist/worker/supabase/auth/signup.js"
            }
        },
        "./worker/supabase/auth/verify": {
            "import": {
                "types": "./dist/worker/supabase/auth/verify.d.ts",
                "default": "./dist/worker/supabase/auth/verify.js"
            }
