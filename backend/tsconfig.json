{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2021"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "teenybase/worker": ["../packages/teenybase/src/worker"],
      "teenybase/worker/supabase": ["../packages/teenybase/src/worker/supabase"],
      "teenybase/worker/supabase/*": ["../packages/teenybase/src/worker/supabase/*"]
    }
  },
  "include": ["worker.ts"]
}
